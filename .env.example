# Copy this file to .env for local development.
# .env is loaded automatically by the FastAPI backend and is ignored by Git.

# Odds Watcher local overrides
ODDS_DB_PATH=data/sgodds_odds.sqlite3

# Admin operation auth. Use strong values in production.
ADMIN_USERNAME=
ADMIN_PASSWORD=
# Prefer ADMIN_PASSWORD_HASH in production. Supported formats:
# - pbkdf2_sha256$iterations$salt$hash
# - sha256:<hex>
ADMIN_PASSWORD_HASH=
AUTH_SECRET_KEY=
AUTH_SESSION_TTL_SECONDS=43200
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_LOGIN_MAX_FAILURES=5
AUTH_LOGIN_WINDOW_SECONDS=300

# Required only for cross-origin frontend/API deployments.
# Same-origin reverse proxy deployments usually do not need this.
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# TheSportsDB V1 free key. Replace with your own key if you have one.
THESPORTSDB_API_KEY=123

# Optional future sources.
API_FOOTBALL_KEY=
